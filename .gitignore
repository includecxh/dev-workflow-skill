# Test/eval data (not needed for installation)
evals/

# Eval workspace (generated during testing)
*-workspace/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# Machine-specific runtime config (generated by install.sh / install.ps1)
# Records the detected Python runtime (uv/python3/none) for ui-ux-pro-max.
# Each machine has its own — never commit.
.runtime-config

# Python bytecode cache (generated when running ui-ux-pro-max search scripts)
__pycache__/
*.pyc
